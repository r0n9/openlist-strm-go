# ==========================================
# Openlist 服务配置 (必填)
# ==========================================

# 访问协议 (http 或 https)
OPENLIST_PROTOCOL=http
# 服务器地址 (IP 或域名)
OPENLIST_HOST=127.0.0.1
# 服务端口 (Alist 等默认通常是 5244)
OPENLIST_PORT=5244
# API 令牌 (必填！请替换为真实的 Token)
OPENLIST_TOKEN=your_openlist_token_here

# ==========================================
# 核心扫描与生成配置
# ==========================================

# 需要扫描的网盘挂载路径 (支持多个，用英文逗号分隔)
SCAN_PATHS=/115,/阿里云盘/Movies
# 本地存放生成的 .strm 和字幕文件的基础路径
STRM_SAVE_PATH=./data
# 截断路径的层级 (例如设为1时，路径 /115/电影 会被截断保留 /电影)
EXCLUDE_OPTION=1
# 是否自动清理本地已失效的 strm 和字幕文件 (1: 开启, 0: 关闭)
DELETE_ABSENT=1

# ==========================================
# SMB 远程同步配置 (选填)
# ==========================================

# 是否开启 SMB 自动同步 (1: 开启, 0: 关闭)
SYNC_TO_SMB=0
# SMB 服务器 IP 地址或主机名
SMB_SERVER=192.168.1.10
# SMB 服务端口 (默认 445)
SMB_PORT=445
# SMB 登录用户名 (公开访问可留空)
SMB_USER=admin
# SMB 登录密码
SMB_PASS=your_password_here
# SMB 顶级共享文件夹名称 (不要包含斜杠)
SMB_SHARE=Media
# 同步到共享文件夹下的具体子目录名称
SMB_DIR=strm